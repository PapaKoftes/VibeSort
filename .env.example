# ── Vibesort .env ─────────────────────────────────────────────────────────────
#
# For most users: this file needs nothing. Just run launch.py and connect.
# The shared Spotify app is baked into the code — no dev account needed.
#
# Security: never commit this file; never paste keys into chat or screenshots.
# Optional keys below are read only from your local machine.
#
# ── Optional: override with your own Spotify app ──────────────────────────────
# If you want to use your own Spotify developer credentials instead:
# VIBESORT_CLIENT_ID=your_client_id_here
# SPOTIFY_CLIENT_ID=your_client_id_here
# SPOTIFY_CLIENT_SECRET=your_client_secret_here
# SPOTIFY_REDIRECT_URI=https://papakoftes.github.io/VibeSort/callback.html

# ── Optional integrations ──────────────────────────────────────────────────────
# Last.fm (last.fm/api) — adds full scrobble history + listening stats
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_USERNAME=

# ListenBrainz (listenbrainz.org/settings/)
LISTENBRAINZ_TOKEN=
LISTENBRAINZ_USERNAME=

# Genius (genius.com/api-clients) — lyrics mood analysis
GENIUS_API_KEY=

# Discogs (discogs.com/settings/developers) — sub-genre styles (Cloud Rap, Shoegaze, etc.)
# No key required (25 req/min free). A token raises the limit to 60 req/min.
DISCOGS_TOKEN=

# Musixmatch (developer.musixmatch.com) — per-track genre via ISRC (2000/day free)
MUSIXMATCH_API_KEY=

# MusicBrainz enrichment (no key needed)
MUSICBRAINZ_ENRICH=false

# ── Spotify genre fetch (Dev Mode: batch /artists often 403 — slow fallback) ──
# Optional: slow down to avoid 429 (defaults are conservative)
# SPOTIFY_ARTIST_GENRE_DELAY=0.35
# SPOTIFY_SEARCH_GENRE_DELAY=0.4
# SPOTIFY_INDIVIDUAL_ARTISTS_CAP=100
# SPOTIFY_SEARCH_GENRES_CAP=50

# ── Scoring (defaults sum to 1.0 with W_METADATA_AUDIO) ───────────────────────
# W_METADATA_AUDIO=0.10
# W_TAGS=0.46
# W_SEMANTIC=0.26
# W_GENRE=0.18
# Optional: learn weights from local events — python -m ml.train_weights
# (uses deploy_playlist + mood_feedback in outputs/events.jsonl)

# When playlist mining is thin/blocked, multiply enrichment API caps (~1.65)
# MINING_FALLBACK_ENRICH_MULT=1.65

# ── Tuning ─────────────────────────────────────────────────────────────────────
PLAYLIST_PREFIX=Vibesort:
MAX_TRACKS_PER_PLAYLIST=50
MIN_SONGS_PER_GENRE=5
MIN_SONGS_PER_ERA=5
MIN_SONGS_PER_ARTIST=8
