# ── OPTION A: Shared app (recommended for distributing to other users) ─────────
# Set this to YOUR Spotify Client ID. End users never need to create their own app.
# Uses PKCE — no client secret needed. Apply for Extended Quota Mode on Spotify
# dashboard so more than 25 users can connect.
VIBESORT_CLIENT_ID=

# ── OPTION B: Your own credentials (personal use / development) ────────────────
# If VIBESORT_CLIENT_ID is set, these are ignored.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Redirect URI — must match your Spotify app's dashboard exactly:
SPOTIFY_REDIRECT_URI=https://papakoftes.github.io/VibeSort/callback.html

# Optional — Last.fm integration (last.fm/api)
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_USERNAME=

# Optional — ListenBrainz (listenbrainz.org/settings/)
LISTENBRAINZ_TOKEN=
LISTENBRAINZ_USERNAME=

# Optional — Genius lyrics (genius.com/api-clients)
GENIUS_API_KEY=

# Optional — MusicBrainz (no key needed, just enable/disable)
MUSICBRAINZ_ENRICH=false

# Optional — Vibesort settings
PLAYLIST_PREFIX=Vibesort:
RECS_PER_PLAYLIST=15
MAX_TRACKS_PER_PLAYLIST=50
MIN_SONGS_PER_GENRE=5
MIN_SONGS_PER_ERA=5
MIN_SONGS_PER_ARTIST=8
COHESION_THRESHOLD=0.60
PLAYLISTS_PER_SEED=4
MINING_FORCE_REFRESH=false
W_AUDIO=0.45
W_TAGS=0.35
W_GENRE=0.20
