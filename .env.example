# Required — get these from developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# This MUST match the Redirect URI you add in your Spotify app dashboard
# When running with Streamlit (default): http://localhost:8501
SPOTIFY_REDIRECT_URI=http://localhost:8501

# Optional — Last.fm integration (last.fm/api)
LASTFM_API_KEY=
LASTFM_API_SECRET=
LASTFM_USERNAME=

# Optional — ListenBrainz (listenbrainz.org/settings/)
LISTENBRAINZ_TOKEN=
LISTENBRAINZ_USERNAME=

# Optional — Genius lyrics (genius.com/api-clients)
GENIUS_API_KEY=

# Optional — MusicBrainz (no key needed, just enable/disable)
MUSICBRAINZ_ENRICH=false

# Optional — Vibesort settings
PLAYLIST_PREFIX=Vibesort:
RECS_PER_PLAYLIST=15
MAX_TRACKS_PER_PLAYLIST=50
MIN_SONGS_PER_GENRE=5
MIN_SONGS_PER_ERA=5
MIN_SONGS_PER_ARTIST=8
COHESION_THRESHOLD=0.60
PLAYLISTS_PER_SEED=4
MINING_FORCE_REFRESH=false
W_AUDIO=0.45
W_TAGS=0.35
W_GENRE=0.20
