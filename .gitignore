# Credentials — never commit
.env
.vibesort_cache

# SSL certs + CA — generated by launch.py, machine-specific
ca.key
ca.crt
cert.pem
key.pem
.ca_installed

# PKCE state — ephemeral auth state, never commit
.vibesort_pkce_state

# Streamlit config — generated by launch.py
.streamlit/

# Outputs — caches, ML events, models (personal / machine-local)
outputs/*
!outputs/.gitkeep

# Local portable release zips (built by scripts/make_portable_zip.ps1)
dist/

# Windows embeddable Python bundle (see docs/PACKAGING.md)
vendor/

# Spotify data export (personal data)
data/StreamingHistory*.json

# Staging shelf — personal playlist data, never commit
staging/playlists/*.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/

# Tests / tooling
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
Thumbs.db
